<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base colors (mirror of HTML :root vars) -->
    <Color x:Key="BgColor">#FF0A0A0A</Color>
    <Color x:Key="SbColor">#FF0F0F0F</Color>
    <Color x:Key="S1Color">#FF161616</Color>
    <Color x:Key="S2Color">#FF1E1E1E</Color>
    <Color x:Key="S3Color">#FF242424</Color>
    <Color x:Key="B1Color">#FF2A2A2A</Color>
    <Color x:Key="B2Color">#FF383838</Color>
    <Color x:Key="AccentColor">#FFC8A96E</Color>
    <Color x:Key="AccentDimColor">#FF6B5A38</Color>
    <Color x:Key="T1Color">#FFE8E4DC</Color>
    <Color x:Key="T2Color">#FF686460</Color>
    <Color x:Key="T3Color">#FF3A3A38</Color>
    <Color x:Key="DangerColor">#FFE05555</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Bg" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="Sb" Color="{StaticResource SbColor}"/>
    <SolidColorBrush x:Key="S1" Color="{StaticResource S1Color}"/>
    <SolidColorBrush x:Key="S2" Color="{StaticResource S2Color}"/>
    <SolidColorBrush x:Key="S3" Color="{StaticResource S3Color}"/>
    <SolidColorBrush x:Key="B1" Color="{StaticResource B1Color}"/>
    <SolidColorBrush x:Key="B2" Color="{StaticResource B2Color}"/>
    <!-- Accent / AccentDim are created in App.xaml.cs as mutable brushes -->
    <!-- (XAML brushes get frozen and can't be animated). -->
    <!-- (DynamicResource lookup finds them in Application.Resources at runtime.) -->
    <!-- AccentColor / AccentDimColor kept for any non-brush consumers. -->
    <!-- <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}"/> -->
    <!-- <SolidColorBrush x:Key="AccentDim" Color="{StaticResource AccentDimColor}"/> -->
    <SolidColorBrush x:Key="T1" Color="{StaticResource T1Color}"/>
    <SolidColorBrush x:Key="T2" Color="{StaticResource T2Color}"/>
    <SolidColorBrush x:Key="T3" Color="{StaticResource T3Color}"/>
    <SolidColorBrush x:Key="Danger" Color="{StaticResource DangerColor}"/>

    <!-- Embedded IBM Plex Mono (TTFs in /fonts) — exactly matches HTML font -->
    <FontFamily x:Key="MonoFont">/fonts/#IBM Plex Mono</FontFamily>
    <FontFamily x:Key="UiFont">/fonts/#IBM Plex Mono</FontFamily>

    <!-- Chrome buttons (min/max): minimal, soft background wash on hover -->
    <Style x:Key="ChromeButton" TargetType="Button">
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource T2}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- Background="Transparent" on root Grid makes the whole 46×32 area hit-testable -->
                    <Grid Background="Transparent">
                        <!-- Background fade -->
                        <Rectangle x:Name="bg" IsHitTestVisible="False">
                            <Rectangle.Fill>
                                <SolidColorBrush x:Name="bdBg" Color="Transparent"/>
                            </Rectangle.Fill>
                        </Rectangle>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource T1}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdBg" Storyboard.TargetProperty="Color"
                                                        To="#1AFFFFFF" Duration="0:0:0.20">
                                            <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdBg" Storyboard.TargetProperty="Color"
                                                        To="Transparent" Duration="0:0:0.22"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Close button: soft red wash on hover -->
    <Style x:Key="ChromeCloseButton" TargetType="Button">
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource T2}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Background="Transparent">
                        <Rectangle IsHitTestVisible="False">
                            <Rectangle.Fill>
                                <SolidColorBrush x:Name="bdBg" Color="Transparent"/>
                            </Rectangle.Fill>
                        </Rectangle>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground"><Setter.Value><SolidColorBrush Color="#FFE05555"/></Setter.Value></Setter>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdBg" Storyboard.TargetProperty="Color"
                                                        To="#22E05555" Duration="0:0:0.20">
                                            <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdBg" Storyboard.TargetProperty="Color"
                                                        To="Transparent" Duration="0:0:0.22"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Row action button (＋ in queue): circular hover bg, smooth color/scale animation -->
    <Style x:Key="RowActionButton" TargetType="Button">
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource T3}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="rowSc" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Ellipse x:Name="bd">
                            <Ellipse.Fill>
                                <SolidColorBrush x:Name="bdBg" Color="Transparent"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource T1}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdBg" Storyboard.TargetProperty="Color" To="#FF242424" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="rowSc" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="rowSc" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdBg" Storyboard.TargetProperty="Color" To="Transparent" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="rowSc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="rowSc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger variant for Delete ✕ — red on hover -->
    <Style x:Key="RowActionDangerButton" TargetType="Button" BasedOn="{StaticResource RowActionButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="rowSc" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Ellipse x:Name="bd">
                            <Ellipse.Fill>
                                <SolidColorBrush x:Name="bdBg" Color="Transparent"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdBg" Storyboard.TargetProperty="Color" To="#22E05555" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="rowSc" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="rowSc" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdBg" Storyboard.TargetProperty="Color" To="Transparent" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="rowSc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="rowSc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Remove dotted focus rectangle on all Buttons globally -->
    <Style TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource T1}"/>
        <Setter Property="CaretBrush" Value="{StaticResource T1}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentDim}"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- Thin scrollbar -->
    <!-- Scrollbar — minimal, hover-expanding (3px → 7px), no buttons -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="root" Width="10">
                        <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="3,4">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border x:Name="thumb"
                                                    Background="#FF2F2F2F"
                                                    CornerRadius="2"
                                                    Width="3"
                                                    HorizontalAlignment="Center"
                                                    SnapsToDevicePixels="True">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}, Path=IsMouseOver}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard><Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Width" To="6" Duration="0:0:0.15"/>
                                                                        <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#FF555555" Duration="0:0:0.15"/>
                                                                    </Storyboard></BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <BeginStoryboard><Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Width" To="3" Duration="0:0:0.20"/>
                                                                        <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#FF2F2F2F" Duration="0:0:0.20"/>
                                                                    </Storyboard></BeginStoryboard>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tooltip — themed to match the dark UI (default WPF tooltip is light/system) -->
    <Style TargetType="ToolTip">
        <Setter Property="Foreground" Value="{StaticResource T1}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="#F5161616" BorderBrush="{StaticResource B2}" BorderThickness="1"
                            CornerRadius="7" Padding="11,7">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="5" Opacity="0.5"/>
                        </Border.Effect>
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Context menu container (rounded with shadow, like HTML #ctxMenu) -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="#F5121212"/>
        <Setter Property="BorderBrush" Value="{StaticResource B1}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Foreground" Value="{StaticResource T1}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}" MinWidth="200">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="14" Opacity="0.6"/>
                        </Border.Effect>
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Context menu MenuItem (modern: accent icon column + submenu arrow + accent hover) -->
    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource T1}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="10,9"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- left accent bar appears on hover -->
                            <Rectangle x:Name="bar" Grid.Column="0" Width="2.5" Height="15" RadiusX="1.5" RadiusY="1.5"
                                       HorizontalAlignment="Left" Margin="-4,0,0,0" Fill="{DynamicResource Accent}" Opacity="0"/>
                            <ContentPresenter Grid.Column="0" ContentSource="Icon" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                            <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center"/>
                            <Path x:Name="arrow" Grid.Column="2" Data="M0,0 L4,4 L0,8" Stroke="{StaticResource T3}" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"
                                  Width="6" Height="9" Stretch="Uniform" VerticalAlignment="Center" Margin="14,0,2,0" Visibility="Collapsed"/>
                            <Popup x:Name="sub" Placement="Right" HorizontalOffset="2" IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#F5121212" BorderBrush="{StaticResource B1}" BorderThickness="1" CornerRadius="10" Padding="6" MinWidth="200" Margin="2,0,10,10">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="14" Opacity="0.6"/>
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="arrow" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bd" Property="Background"><Setter.Value><SolidColorBrush Color="#1FC8A96E"/></Setter.Value></Setter>
                            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            <Setter TargetName="arrow" Property="Stroke" Value="{DynamicResource Accent}"/>
                            <Setter TargetName="bar" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger MenuItem variant (red icon + hover) -->
    <Style x:Key="DangerMenuItem" TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
        <Setter Property="Foreground" Value="{StaticResource T2}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle x:Name="bar" Grid.Column="0" Width="2.5" Height="15" RadiusX="1.5" RadiusY="1.5"
                                       HorizontalAlignment="Left" Margin="-4,0,0,0" Fill="{StaticResource Danger}" Opacity="0"/>
                            <ContentPresenter Grid.Column="0" ContentSource="Icon" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                            <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bd" Property="Background"><Setter.Value><SolidColorBrush Color="#1F5A2A2A"/></Setter.Value></Setter>
                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                            <Setter TargetName="bar" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Context menu separator (HTML .ctx-sep: 1px line, margin 5px 8px) -->
    <Style TargetType="Separator">
        <Setter Property="Margin" Value="8,5"/>
        <Setter Property="Background" Value="{StaticResource B1}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Background="{TemplateBinding Background}" Height="1"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Button base style (transparent, hover bg) -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource T2}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                            <Setter Property="Foreground" Value="{StaticResource T1}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar action button — with icon + label + gradient sweep -->
    <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="Padding" Value="11,9"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{StaticResource S1}"
                            BorderBrush="{StaticResource B1}" BorderThickness="1"
                            CornerRadius="7" ClipToBounds="True">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="lift" X="0"/>
                        </Border.RenderTransform>
                        <Grid>
                            <!-- Gradient sweep -->
                            <Rectangle x:Name="sweep" Width="0" HorizontalAlignment="Left" IsHitTestVisible="False">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#10C8A96E" Offset="0"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource T1}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#FF1E1E1E" Duration="0:0:0.15"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#FF383838" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="lift" Storyboard.TargetProperty="X" To="2" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="sweep" Storyboard.TargetProperty="Width" To="220" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#FF161616" Duration="0:0:0.15"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#FF2A2A2A" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="lift" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="sweep" Storyboard.TargetProperty="Width" To="0" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar action button — DANGER variant (red on hover) -->
    <Style x:Key="SidebarDangerButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="Padding" Value="11,9"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{StaticResource S1}"
                            BorderBrush="{StaticResource B1}" BorderThickness="1"
                            CornerRadius="7" ClipToBounds="True">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="lift" X="0"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Rectangle x:Name="sweep" Width="0" HorizontalAlignment="Left" IsHitTestVisible="False">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#0DE05555" Offset="0"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#145A2A2A" Duration="0:0:0.15"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#FF5A2A2A" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="lift" Storyboard.TargetProperty="X" To="2" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="sweep" Storyboard.TargetProperty="Width" To="220" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#FF161616" Duration="0:0:0.15"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#FF2A2A2A" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="lift" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="sweep" Storyboard.TargetProperty="Width" To="0" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Pill button (Queue, Profile in header) — with smooth animations -->
    <!-- Dropdown menu item (Sort popup) -->
    <Style x:Key="SortMenuItem" TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="11,8">
                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="12" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                            <Setter Property="Foreground" Value="{StaticResource T1}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PillButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="Padding" Value="14,9"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{StaticResource S1}"
                            BorderBrush="{StaticResource B1}" BorderThickness="1"
                            CornerRadius="9" Padding="{TemplateBinding Padding}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="liftTransform" Y="0"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect x:Name="bdShadow" Color="Black" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource T1}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#FF1E1E1E" Duration="0:0:0.18"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#FF383838" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="liftTransform" Storyboard.TargetProperty="Y" To="-1" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="bdShadow" Storyboard.TargetProperty="BlurRadius" To="12" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="bdShadow" Storyboard.TargetProperty="Opacity" To="0.3" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#FF161616" Duration="0:0:0.18"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#FF2A2A2A" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="liftTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="bdShadow" Storyboard.TargetProperty="BlurRadius" To="0" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="bdShadow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="Tag" Value="active">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentDim}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            <!-- HTML .ft.active { box-shadow: 0 0 0 3px rgba(200,169,110,.06) } — accent ring via storyboard -->
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdShadow" Storyboard.TargetProperty="Color" To="#C8A96E" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="bdShadow" Storyboard.TargetProperty="BlurRadius" To="10" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="bdShadow" Storyboard.TargetProperty="Opacity" To="0.22" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bdShadow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="bdShadow" Storyboard.TargetProperty="BlurRadius" To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Round play button (white circle) — scale + glow on hover -->
    <Style x:Key="PlayCircleButton" TargetType="Button">
        <Setter Property="Width" Value="42"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource Bg}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="playScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                        <!-- Idle: white. On hover: animated to current accent color (driven from code) -->
                        <Ellipse x:Name="el">
                            <Ellipse.Fill>
                                <SolidColorBrush x:Name="playFill" Color="#FFE8E4DC"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="playScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="playScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="playScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="playScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Small ctrl button: Foreground T1 (white) by default, dim opacity. -->
    <!-- Active state (shuffle/repeat/mute on) is set in code-behind: Foreground=Accent, Opacity=1.0 -->
    <Style x:Key="CtrlButton" TargetType="Button">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource T1}"/>
        <Setter Property="Opacity" Value="0.65"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="ctrlScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                        <Ellipse Fill="Transparent"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ctrlScale" Storyboard.TargetProperty="ScaleX" To="1.12" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="ctrlScale" Storyboard.TargetProperty="ScaleY" To="1.12" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ctrlScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="ctrlScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
