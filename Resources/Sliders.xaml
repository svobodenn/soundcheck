<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:SoundCheck.Helpers">

    <helpers:SliderFillConverter x:Key="SliderFillCv"/>

    <!-- Thumb template — small white circle, fades in on slider hover -->
    <ControlTemplate x:Key="SliderThumbTpl" TargetType="Thumb">
        <Grid Width="14" Height="14">
            <Ellipse x:Name="ThumbEllipse" Fill="{StaticResource T1}" Width="12" Height="12"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Opacity="0">
                <Ellipse.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.55"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=IsMouseOver}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ThumbEllipse" Storyboard.TargetProperty="Opacity"
                                             To="1" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ThumbEllipse" Storyboard.TargetProperty="Opacity"
                                             To="0" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Fill RepeatButton (left side of thumb) -->
    <ControlTemplate x:Key="FillBtnTpl" TargetType="RepeatButton">
        <Border x:Name="FillBorder" Background="{TemplateBinding Foreground}" Height="4" CornerRadius="2" VerticalAlignment="Center"/>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=IsMouseOver}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="FillBorder" Storyboard.TargetProperty="Height" To="6" Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="FillBorder" Storyboard.TargetProperty="Height" To="4" Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="EmptyBtnTpl" TargetType="RepeatButton">
        <Border Background="Transparent"/>
    </ControlTemplate>

    <!-- Track background — also grows on hover -->
    <!-- Used inline below -->

    <!-- ThinSlider: flat solid accent fill (used by volume slider) -->
    <Style x:Key="ThinSlider" TargetType="Slider"
           xmlns:h="clr-namespace:SoundCheck.Helpers">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="h:SliderBehavior.ClickToSeek" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid x:Name="root" Height="22" Background="Transparent">
                        <Border x:Name="TrackBg" Background="{StaticResource S3}"
                                Height="4" CornerRadius="2" VerticalAlignment="Center"/>
                        <Border x:Name="Fill" Background="{DynamicResource Accent}"
                                Height="4" CornerRadius="2"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                IsHitTestVisible="False">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource SliderFillCv}">
                                    <Binding Path="Value"     RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Maximum"   RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Minimum"   RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="ActualWidth" ElementName="root"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                        <Ellipse x:Name="ThumbDot" Width="12" Height="12" Fill="{StaticResource T1}"
                                 HorizontalAlignment="Left" VerticalAlignment="Center" Opacity="0"
                                 IsHitTestVisible="False">
                            <Ellipse.Margin>
                                <MultiBinding Converter="{StaticResource SliderFillCv}" ConverterParameter="thumb">
                                    <Binding Path="Value"     RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Maximum"   RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Minimum"   RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="ActualWidth" ElementName="root"/>
                                </MultiBinding>
                            </Ellipse.Margin>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.55"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="TrackBg" Storyboard.TargetProperty="Height" To="6" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="Fill" Storyboard.TargetProperty="Height" To="6" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="ThumbDot" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                </Storyboard></BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="TrackBg" Storyboard.TargetProperty="Height" To="4" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="Fill" Storyboard.TargetProperty="Height" To="4" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="ThumbDot" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                </Storyboard></BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- WaveSlider: progress bar with elegant equalizer-bars fill (vertical mini-bars showing audio shape) -->
    <Style x:Key="WaveSlider" TargetType="Slider"
           xmlns:h="clr-namespace:SoundCheck.Helpers">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="h:SliderBehavior.ClickToSeek" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid x:Name="root" Height="22" Background="Transparent">
                        <!-- Unplayed: thin line only after played-portion (right-aligned, width = remaining) -->
                        <Border x:Name="TrackBg" Background="{StaticResource S3}"
                                Height="3" CornerRadius="1.5" VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource SliderFillCv}" ConverterParameter="remaining">
                                    <Binding Path="Value"     RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Maximum"   RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Minimum"   RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="ActualWidth" ElementName="root"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                        <!-- Played: clipped container with N tiny vertical accent bars across full width -->
                        <Border x:Name="Fill" ClipToBounds="True"
                                Height="22" HorizontalAlignment="Left" VerticalAlignment="Center"
                                IsHitTestVisible="False">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource SliderFillCv}">
                                    <Binding Path="Value"     RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Maximum"   RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Minimum"   RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="ActualWidth" ElementName="root"/>
                                </MultiBinding>
                            </Border.Width>
                            <ItemsControl x:Name="WaveBarsHost" Width="{Binding ActualWidth, ElementName=root}"
                                          HorizontalAlignment="Left" VerticalAlignment="Center"
                                          helpers:WaveBars.Source="{Binding ElementName=root}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Rectangle Width="3" Margin="1,0" Fill="{DynamicResource Accent}"
                                                   Height="{Binding}" RadiusX="1.5" RadiusY="1.5"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                        <!-- Thumb circle anchored at fill end -->
                        <Ellipse x:Name="ThumbDot" Width="12" Height="12" Fill="{StaticResource T1}"
                                 HorizontalAlignment="Left" VerticalAlignment="Center" Opacity="0"
                                 IsHitTestVisible="False">
                            <Ellipse.Margin>
                                <MultiBinding Converter="{StaticResource SliderFillCv}" ConverterParameter="thumb">
                                    <Binding Path="Value"     RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Maximum"   RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Minimum"   RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="ActualWidth" ElementName="root"/>
                                </MultiBinding>
                            </Ellipse.Margin>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.55"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ThumbDot" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                </Storyboard></BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ThumbDot" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                </Storyboard></BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
