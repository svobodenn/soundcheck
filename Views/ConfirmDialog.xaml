<UserControl x:Class="SoundCheck.Views.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#CC050505"
             Opacity="0"
             Visibility="Collapsed"
             RenderTransformOrigin="0.5,0.5">
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="CdScale" ScaleX="0.94" ScaleY="0.94"/>
    </UserControl.RenderTransform>
    <Grid x:Name="BackdropGrid">
        <Border Width="420" MaxWidth="500"
                Background="{StaticResource Sb}"
                BorderBrush="{StaticResource B1}" BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="28,26,28,22">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="12" Opacity="0.55"/>
            </Border.Effect>
            <StackPanel>
                <!-- Accent stripe at top -->
                <Border Background="{DynamicResource Accent}" Height="3" Width="40" CornerRadius="2"
                        HorizontalAlignment="Left" Margin="0,0,0,16"/>
                <TextBlock x:Name="TxtTitle" Text="{DynamicResource L_ConfirmTitle}"
                           Foreground="{StaticResource T3}" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <TextBlock x:Name="TxtMessage" Text=""
                           Foreground="{StaticResource T1}" FontSize="16" FontWeight="Medium"
                           TextWrapping="Wrap" Margin="0,0,0,24"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancel" Content="{DynamicResource L_ConfirmCancel}" Click="Cancel_Click" Margin="0,0,10,0"
                            FontWeight="Bold" FontSize="11" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent"
                                        BorderBrush="{StaticResource B1}" BorderThickness="1"
                                        CornerRadius="7" Padding="20,9">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                                        <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource B2}"/>
                                        <Setter Property="Foreground" Value="{StaticResource T1}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground><SolidColorBrush Color="#FF686460"/></Button.Foreground>
                    </Button>
                    <Button x:Name="BtnConfirm" Content="{DynamicResource L_ConfirmOk}" Click="Confirm_Click"
                            FontWeight="Bold" FontSize="11" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent"
                                        BorderBrush="Transparent" BorderThickness="1"
                                        CornerRadius="7" Padding="20,9">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background"><Setter.Value><SolidColorBrush Color="#145A2A2A"/></Setter.Value></Setter>
                                        <Setter TargetName="bd" Property="BorderBrush"><Setter.Value><SolidColorBrush Color="#FF5A2A2A"/></Setter.Value></Setter>
                                        <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground><SolidColorBrush Color="#FFE05555"/></Button.Foreground>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
