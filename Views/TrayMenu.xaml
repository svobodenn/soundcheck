<Window x:Class="SoundCheck.Views.TrayMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        SizeToContent="WidthAndHeight"
        MaxWidth="340"
        ResizeMode="NoResize"
        MouseEnter="OnMouseEnter"
        MouseLeave="OnMouseLeave"
        Loaded="OnLoaded"
        Opacity="0">
    <Border Background="{StaticResource Sb}"
            BorderBrush="{StaticResource B1}" BorderThickness="1"
            CornerRadius="10"
            Padding="6,8,6,8"
            MinWidth="252"
            RenderTransformOrigin="0.5,1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="6" Opacity="0.55"/>
        </Border.Effect>
        <Border.RenderTransform>
            <ScaleTransform x:Name="MenuScale" ScaleX="0.94" ScaleY="0.94"/>
        </Border.RenderTransform>

        <StackPanel>
            <!-- HEADER: cover + title -->
            <Grid Margin="6,2,6,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="5" ClipToBounds="True" Background="{StaticResource S3}" Margin="0,0,10,0">
                    <Grid>
                        <Path Data="{StaticResource LogoGeo}" Fill="{StaticResource T3}" Width="14" Height="14" Stretch="Uniform" Opacity="0.4"/>
                        <Image x:Name="ImgCover" Stretch="UniformToFill"/>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTitle" Text="soundcheck" Foreground="{StaticResource T1}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TxtArtist" Text="{DynamicResource L_TrayNothing}" Foreground="{StaticResource T3}" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>

            <Rectangle Fill="{StaticResource B1}" Height="1" Margin="2,0,2,4" Opacity="0.6"/>

            <!-- TRANSPORT CONTROLS row -->
            <Grid Margin="4,4,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Shuffle -->
                <Button x:Name="BtnShuffle" Grid.Column="0" Cursor="Hand" Click="BtnShuffle_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="7" Padding="0,9" Margin="2,0">
                                <Path x:Name="ic" Data="{StaticResource ShuffleGeo}" Stroke="{StaticResource T2}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnPrev" Grid.Column="1" Cursor="Hand" Click="BtnPrev_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="7" Padding="0,9" Margin="2,0">
                                <Path Data="{StaticResource PrevGeo}" Fill="{StaticResource T2}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnPlay" Grid.Column="2" Cursor="Hand" Click="BtnPlay_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{DynamicResource Accent}" CornerRadius="7" Padding="0,10" Margin="2,0">
                                <Path x:Name="PathPlay" Data="{StaticResource PlayGeo}" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center">
                                    <Path.Fill><SolidColorBrush Color="#FF0E0E0E"/></Path.Fill>
                                </Path>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnNext" Grid.Column="3" Cursor="Hand" Click="BtnNext_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="7" Padding="0,9" Margin="2,0">
                                <Path Data="{StaticResource NextGeo}" Fill="{StaticResource T2}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Repeat -->
                <Button x:Name="BtnRepeat" Grid.Column="4" Cursor="Hand" Click="BtnRepeat_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="7" Padding="0,9" Margin="2,0">
                                <Path x:Name="ic" Data="{StaticResource RepeatGeo}" Stroke="{StaticResource T2}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- VOLUME row -->
            <Grid Margin="10,2,12,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="0" Data="{StaticResource VolumeGeo}" Stroke="{StaticResource T2}" StrokeThickness="1.5"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                      Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,11,0"/>
                <Slider x:Name="SldVol" Grid.Column="1" Minimum="0" Maximum="1" Value="0.8"
                        Style="{StaticResource ThinSlider}" VerticalAlignment="Center"
                        ValueChanged="SldVol_ValueChanged"/>
            </Grid>

            <Rectangle Fill="{StaticResource B1}" Height="1" Margin="2,4,2,4" Opacity="0.6"/>

            <!-- MENU ITEMS -->
            <Button x:Name="BtnShow" Click="BtnShow_Click" Cursor="Hand" HorizontalContentAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="12,9">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M3,12 L10,5 L10,9 L21,9 L21,15 L10,15 L10,19 Z" Fill="{StaticResource T2}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource L_TrayShow}" Foreground="{StaticResource T1}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="BtnQuit" Click="BtnQuit_Click" Cursor="Hand" HorizontalContentAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="12,9">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M18,6 L6,18 M6,6 L18,18" Stroke="{StaticResource T3}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Width="13" Height="13" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource L_TrayQuit}" Foreground="{StaticResource T2}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"><Setter.Value><SolidColorBrush Color="#145A2A2A"/></Setter.Value></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>
