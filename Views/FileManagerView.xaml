<UserControl x:Class="SoundCheck.Views.FileManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:SoundCheck.Helpers"
             Background="#EB050505"
             Opacity="0"
             RenderTransformOrigin="0.5,0.5">
    <UserControl.RenderTransform>
        <TransformGroup>
            <ScaleTransform x:Name="StScale" ScaleX="0.96" ScaleY="0.96"/>
            <TranslateTransform x:Name="StTrans" Y="22"/>
        </TransformGroup>
    </UserControl.RenderTransform>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Outline button -->
        <Style x:Key="FmOutline" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource T2}"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource S2}" BorderBrush="{StaticResource B1}" BorderThickness="1" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource S3}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource B2}"/>
                                <Setter Property="Foreground" Value="{StaticResource T1}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent-filled button (Browse / Rename) -->
        <Style x:Key="FmAccent" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground"><Setter.Value><SolidColorBrush Color="#FF0E0E0E"/></Setter.Value></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{DynamicResource Accent}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Square selection checkbox -->
        <Style x:Key="FmCheck" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="box" Width="18" Height="18" CornerRadius="5"
                                Background="{StaticResource S2}" BorderBrush="{StaticResource B2}" BorderThickness="1">
                            <Path x:Name="tick" Data="M4,9 L8,13 L14,5" Stroke="#FF0E0E0E" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Stretch="Uniform" Margin="3" Visibility="Collapsed"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="tick" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed ComboBox (no default blue chrome) -->
        <Style x:Key="FmComboItem" TargetType="ComboBoxItem">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource T2}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="5" Padding="12,8" Margin="4,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                                <Setter Property="Foreground" Value="{StaticResource T1}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FmCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource T1}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource FmComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="{StaticResource S2}" BorderBrush="{StaticResource B1}" BorderThickness="1" CornerRadius="7" Padding="12,8">
                                            <Grid>
                                                <ContentPresenter Margin="0,0,22,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                                  TextElement.Foreground="{StaticResource T1}"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <Path Data="M1,3 L6,8 L11,3" Stroke="{StaticResource T2}" StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      HorizontalAlignment="Right" VerticalAlignment="Center" Width="12" Height="7" Stretch="Uniform"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource B2}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True" Placement="Bottom" PopupAnimation="Fade" Focusable="False">
                                <Border Background="{StaticResource S1}" BorderBrush="{StaticResource B1}" BorderThickness="1" CornerRadius="7"
                                        Margin="0,4,0,0" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        Padding="0,4">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
                                    </Border.Effect>
                                    <ItemsPresenter/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="BackdropGrid" Background="Transparent" MouseLeftButtonDown="Backdrop_MouseDown">
        <Border Width="900" MinHeight="560" MaxHeight="960" Margin="0,40"
                Background="{StaticResource Sb}"
                BorderBrush="{StaticResource B1}" BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center" VerticalAlignment="Stretch"
                MouseLeftButtonDown="Card_MouseDown">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="12" Opacity="0.55"/>
            </Border.Effect>
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border Grid.Row="0" Padding="28,22,18,18" BorderBrush="{StaticResource B1}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid>
                            <Border Background="{DynamicResource Accent}" Width="3" Height="32" HorizontalAlignment="Left" CornerRadius="2"/>
                            <StackPanel Margin="16,0,0,0">
                                <TextBlock Text="{DynamicResource L_FmTitle}" Foreground="{StaticResource T1}" FontSize="22" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource L_FmSubtitle}" Foreground="{StaticResource T2}" FontSize="12" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Button x:Name="BtnClose" Style="{StaticResource PillButton}"
                                Content="{DynamicResource L_BtnCloseShort}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Foreground="{StaticResource T3}" Padding="14,7" FontSize="12" FontWeight="Bold"
                                Click="BtnClose_Click"/>
                    </Grid>
                </Border>

                <!-- PATH -->
                <Grid Grid.Row="1" Margin="28,18,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource S1}" BorderBrush="{StaticResource B1}" BorderThickness="1" CornerRadius="7" Margin="0,0,10,0">
                        <Grid>
                            <TextBox x:Name="TxtPath" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource T1}" CaretBrush="{StaticResource T1}" FontSize="13"
                                     Padding="14,10" VerticalContentAlignment="Center"
                                     FontFamily="Consolas, Courier New" KeyDown="TxtPath_KeyDown" TextChanged="TxtPath_TextChanged"/>
                            <TextBlock x:Name="TxtPathPh" Text="{DynamicResource L_FmPathPh}" Foreground="{StaticResource T2}"
                                       FontSize="13" Margin="15,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                    <Button Grid.Column="1" Style="{StaticResource FmAccent}" Margin="0,0,8,0" Click="BtnBrowse_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FolderGeo}" Stroke="#FF0E0E0E" StrokeThickness="1.6" Fill="Transparent" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource L_FmBrowse}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource FmOutline}" Click="BtnRefresh_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M21,12 A9,9 0 1 1 18,5.3 M21,3 L21,8 L16,8" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource L_FmRefresh}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- TABS -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="28,16,28,0">
                    <Border x:Name="TabTrack" Background="{DynamicResource Accent}" CornerRadius="7" Padding="14,8" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FileGeo}" Stroke="#FF0E0E0E" StrokeThickness="1.4" Fill="Transparent" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13" FontWeight="Bold" Foreground="#FF0E0E0E">
                                <Run Text="{DynamicResource L_FmTabTrack}"/><Run Text=" ("/><Run x:Name="RunTrackCount" Text="0"/><Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource S1}" BorderBrush="{StaticResource B1}" BorderThickness="1" CornerRadius="7" Padding="14,8" Margin="0,0,8,0" Opacity="0.45">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FileGeo}" Stroke="{StaticResource T2}" StrokeThickness="1.4" Fill="Transparent" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource T2}">
                                <Run Text="{DynamicResource L_FmTabLyric}"/><Run Text=" (0)"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource S1}" BorderBrush="{StaticResource B1}" BorderThickness="1" CornerRadius="7" Padding="14,8" Opacity="0.45">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FolderGeo}" Stroke="{StaticResource T2}" StrokeThickness="1.4" Fill="Transparent" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource T2}">
                                <Run Text="{DynamicResource L_FmTabCover}"/><Run Text=" (0)"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RENAME FORMAT -->
                <StackPanel Grid.Row="3" Margin="28,18,28,0">
                    <TextBlock Text="{DynamicResource L_FmRenameFormat}" Foreground="{StaticResource T2}" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="CmbFormat" Style="{StaticResource FmCombo}" Width="240" SelectionChanged="CmbFormat_SelectionChanged"/>
                        <Button x:Name="BtnFormatReset" Style="{StaticResource FmOutline}" Padding="10,8" Margin="8,0,0,0" Click="BtnFormatReset_Click" ToolTip="{DynamicResource L_ResetLink}">
                            <Path Data="M2,8 A6,6 0 1 0 4,3.5 M2,3 L2,8 L7,8" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Width="15" Height="15" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource T2}" FontFamily="Consolas, Courier New" TextTrimming="CharacterEllipsis">
                        <Run Text="{DynamicResource L_FmPreviewLabel}"/><Run x:Name="RunPreview" Foreground="{StaticResource T1}" Text=""/>
                    </TextBlock>
                </StackPanel>

                <!-- TOOLBAR -->
                <Border Grid.Row="4" Margin="28,16,28,0" Background="{StaticResource S1}" BorderBrush="{StaticResource B1}" BorderThickness="1" CornerRadius="9,9,0,0" Padding="16,12">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="ChkSelectAll" Style="{StaticResource FmCheck}" Checked="SelectAll_Changed" Unchecked="SelectAll_Changed"/>
                            <TextBlock Text="{DynamicResource L_FmSelectAll}" Foreground="{StaticResource T1}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock x:Name="TxtSelCount" Foreground="{StaticResource T2}" FontSize="13" VerticalAlignment="Center" Margin="18,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnPreview" Style="{StaticResource FmOutline}" Content="{DynamicResource L_FmPreviewBtn}" Margin="0,0,8,0" Click="BtnPreview_Click"/>
                            <Button x:Name="BtnRename" Style="{StaticResource FmAccent}" Content="{DynamicResource L_FmRenameBtn}" Click="BtnRename_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- LIST -->
                <Border Grid.Row="5" Margin="28,0,28,0" Background="{StaticResource S1}" BorderBrush="{StaticResource B1}" BorderThickness="1,0,1,1" CornerRadius="0,0,9,9">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" helpers:SmoothScroll.Enabled="True" Padding="4,6">
                            <ItemsControl x:Name="GroupsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <!-- group header -->
                                            <Border Cursor="Hand" Padding="8,7" Margin="2,2,2,0" CornerRadius="6"
                                                    MouseLeftButtonUp="Group_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource S2}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Width="9" Height="9" Stretch="Uniform" Margin="2,0,8,0" VerticalAlignment="Center"
                                                          Data="M3,2 L8,6.5 L3,11" Stroke="{StaticResource T2}" StrokeThickness="1.6"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="RenderTransform"><Setter.Value><RotateTransform Angle="0"/></Setter.Value></Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                        <Setter Property="RenderTransform"><Setter.Value><RotateTransform Angle="90"/></Setter.Value></Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                    <Path Data="{StaticResource FolderGeo}" Stroke="{DynamicResource Accent}" StrokeThickness="1.5" Fill="Transparent" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding FolderName}" Foreground="{StaticResource T1}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="9,0,0,0"/>
                                                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource T2}" FontSize="12">
                                                        <Run Text="("/><Run Text="{Binding Count, Mode=OneWay}"/><Run Text=")"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <!-- files -->
                                            <ItemsControl ItemsSource="{Binding Files}" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="7" Margin="2,1" Padding="10,7">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource S2}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="0" Style="{StaticResource FmCheck}" Margin="6,0,12,0"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                                                <Path Grid.Column="1" Data="{StaticResource FileGeo}" Stroke="{DynamicResource Accent}" StrokeThickness="1.3" Fill="Transparent"
                                                                      Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding Display}" VerticalAlignment="Center" FontSize="13"
                                                                           TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource T1}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Highlight}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Grid.Column="3" Text="{Binding SizeText}" Foreground="{StaticResource T2}" FontSize="12" VerticalAlignment="Center" Margin="12,0,8,0"/>
                                                                <!-- Edit tags (visible on row hover) -->
                                                                <Button Grid.Column="4" Click="EditTags_Click" Cursor="Hand" VerticalAlignment="Center"
                                                                        ToolTip="{DynamicResource L_CtxEditTags}" Width="26" Height="26" Margin="0,0,2,0">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button">
                                                                            <Setter Property="Opacity" Value="0"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                                                                                            <Path Data="M4,14 L4,11 L13,2 L16,5 L7,14 Z M11,4 L14,7" Stroke="{StaticResource T2}" StrokeThickness="1.5"
                                                                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                                                                  Width="15" Height="15" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource S3}"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                                                    <Setter Property="Opacity" Value="1"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="TxtEmpty" Text="{DynamicResource L_FmEmpty}" Foreground="{StaticResource T2}" FontSize="13"
                                   TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
                    </Grid>
                </Border>

                <!-- STATUS -->
                <Border Grid.Row="6" BorderBrush="{StaticResource B1}" BorderThickness="0,1,0,0" Padding="28,12,28,14">
                    <TextBlock x:Name="TxtStatus" Foreground="{StaticResource T2}" FontSize="12" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
