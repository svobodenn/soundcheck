<UserControl x:Class="SoundCheck.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:SoundCheck.Helpers"
             Background="#EB050505"
             RenderTransformOrigin="0.5,0.5"
             Opacity="0">
    <UserControl.RenderTransform>
        <TransformGroup>
            <ScaleTransform x:Name="PfScale" ScaleX="0.96" ScaleY="0.96"/>
            <TranslateTransform x:Name="PfTrans" Y="26"/>
        </TransformGroup>
    </UserControl.RenderTransform>

    <UserControl.Resources>
        <!-- Stat number card -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource S1}"/>
            <Setter Property="BorderBrush" Value="{StaticResource B1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="22,20"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource S2}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource B2}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section panel card -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource S1}"/>
            <Setter Property="BorderBrush" Value="{StaticResource B1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24,20"/>
        </Style>

        <!-- Cover thumb (top / history rows) -->
        <Style x:Key="RowCover" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="{StaticResource S2}"/>
            <Setter Property="BorderBrush" Value="{StaticResource B1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
    </UserControl.Resources>

    <!-- Backdrop click closes -->
    <Grid x:Name="BackdropGrid" Background="Transparent" MouseLeftButtonDown="Backdrop_MouseDown">
        <Border Width="820" MaxHeight="900"
                Background="{StaticResource Sb}"
                BorderBrush="{StaticResource B1}" BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MouseLeftButtonDown="Card_MouseDown">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="12" Opacity="0.55"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="CardTrans" Y="0"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HERO -->
                <Border Grid.Row="0" Padding="32,26,18,24" BorderBrush="{StaticResource B1}" BorderThickness="0,0,0,1" ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#14C8A96E" Offset="0"/>
                            <GradientStop Color="#00C8A96E" Offset="0.55"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Canvas IsHitTestVisible="False" ClipToBounds="False">
                            <Ellipse Width="320" Height="320" Canvas.Right="-40" Canvas.Top="-150" IsHitTestVisible="False">
                                <Ellipse.Fill>
                                    <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5">
                                        <GradientStop Color="#17C8A96E" Offset="0"/>
                                        <GradientStop Color="#00000000" Offset="0.7"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Canvas>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="HeroAvatar" Width="72" Height="72" CornerRadius="36"
                                    Background="{StaticResource S2}"
                                    BorderBrush="{DynamicResource AccentDim}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="AvatarGlow" Color="#C8A96E" BlurRadius="14" ShadowDepth="0" Opacity="0.14"/>
                                </Border.Effect>
                                <Path Data="{StaticResource StatsGeo}" Fill="{DynamicResource Accent}"
                                      Width="32" Height="32" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="24,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource L_ProfileHeader}" Foreground="{StaticResource T2}" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock Text="{DynamicResource L_ProfileSubtitle}" Foreground="{StaticResource T1}" FontSize="24" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="BtnClose" Style="{StaticResource PillButton}" Content="{DynamicResource L_BtnCloseShort}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Padding="14,7" FontSize="12" FontWeight="Bold" Foreground="{StaticResource T3}"
                                Click="BtnClose_Click"/>
                    </Grid>
                </Border>

                <!-- BODY -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" helpers:SmoothScroll.Enabled="True">
                    <StackPanel Margin="24,20,24,24">

                        <!-- STAT CARDS -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock x:Name="TxtTracksCount" Text="0" Foreground="{DynamicResource Accent}" FontSize="34" FontWeight="Bold"/>
                                    <TextBlock Text="{DynamicResource L_ProfileTracksLabel}" Foreground="{StaticResource T2}" FontSize="11" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource Accent}" FontSize="34" FontWeight="Bold">
                                        <Run x:Name="TxtTotalListenedVal" Text="0"/><Run x:Name="TxtTotalListenedUnit" Foreground="{StaticResource T2}" FontSize="17" FontWeight="Light" Text=""/><Run x:Name="TxtTotalListenedVal2" Text=""/><Run x:Name="TxtTotalListenedUnit2" Foreground="{StaticResource T2}" FontSize="17" FontWeight="Light" Text=""/>
                                    </TextBlock>
                                    <TextBlock Text="{DynamicResource L_ProfileListenedLabel}" Foreground="{StaticResource T2}" FontSize="11" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock x:Name="TxtTotalPlays" Text="0" Foreground="{DynamicResource Accent}" FontSize="34" FontWeight="Bold"/>
                                    <TextBlock Text="{DynamicResource L_ProfilePlaysLabel}" Foreground="{StaticResource T2}" FontSize="11" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ACTIVITY -->
                        <Border Style="{StaticResource SectionCard}" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource L_ProfileActivity}" Foreground="{StaticResource T2}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{DynamicResource L_ProfileDay30}" Foreground="{StaticResource T2}" FontSize="12" Margin="0,0,0,8"/>
                                <StackPanel x:Name="DayChartHost" Orientation="Horizontal" Height="64" HorizontalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource L_ProfileHours}" Foreground="{StaticResource T2}" FontSize="12" Margin="0,16,0,8"/>
                                <StackPanel x:Name="HourChartHost" Orientation="Horizontal" HorizontalAlignment="Center"/>
                                <StackPanel x:Name="HourLabelsHost" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- TOP TRACKS -->
                        <Border Style="{StaticResource SectionCard}" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource L_ProfileTop}" Foreground="{StaticResource T2}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ItemsControl x:Name="TopList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Margin" Value="0,9,0,9"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Margin" Value="6,9,0,9"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="54"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Rank}" Foreground="{StaticResource T2}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0,0,14,0"/>
                                                <Border Grid.Column="1" Style="{StaticResource RowCover}">
                                                    <Grid>
                                                        <Path Data="M9,18 L9,5 L21,3 L21,16 M9,18 A3,3 0 1 1 3,18 A3,3 0 1 1 9,18 M21,16 A3,3 0 1 1 15,16 A3,3 0 1 1 21,16"
                                                              Stroke="{StaticResource T2}" StrokeThickness="1.5" Fill="Transparent"
                                                              Width="16" Height="16" Stretch="Uniform"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource T1}" FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Artist}" Foreground="{StaticResource T2}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="3" Background="{StaticResource S3}" Height="4" CornerRadius="2" VerticalAlignment="Center" Margin="6,0">
                                                    <Border HorizontalAlignment="Left" Background="{DynamicResource Accent}" Width="{Binding BarWidth}" CornerRadius="2"/>
                                                </Border>
                                                <TextBlock Grid.Column="4" Text="{Binding Plays, StringFormat={}{0}×}" Foreground="{StaticResource T2}" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="TxtTopEmpty" Text="{DynamicResource L_ProfileEmptyTop}" Foreground="{StaticResource T2}" FontSize="13" TextAlignment="Center" Padding="0,20" Visibility="Visible" TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <!-- HISTORY -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource L_ProfileHistory}" Foreground="{StaticResource T2}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ItemsControl x:Name="HistList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,9">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="54"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Rank}" Foreground="{StaticResource T2}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0,0,14,0"/>
                                                <Border Grid.Column="1" Style="{StaticResource RowCover}">
                                                    <Grid>
                                                        <Path Data="M9,18 L9,5 L21,3 L21,16 M9,18 A3,3 0 1 1 3,18 A3,3 0 1 1 9,18 M21,16 A3,3 0 1 1 15,16 A3,3 0 1 1 21,16"
                                                              Stroke="{StaticResource T2}" StrokeThickness="1.5" Fill="Transparent"
                                                              Width="16" Height="16" Stretch="Uniform"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource T1}" FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Artist}" Foreground="{StaticResource T2}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="{Binding Ago}" Foreground="{StaticResource T2}" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="TxtHistEmpty" Text="{DynamicResource L_ProfileEmptyHist}" Foreground="{StaticResource T2}" FontSize="13" TextAlignment="Center" Padding="0,20" TextWrapping="Wrap" LineHeight="20"/>
                                <Button x:Name="BtnReset" Content="{DynamicResource L_ProfileReset}" Click="BtnReset_Click"
                                        HorizontalAlignment="Left" Margin="0,18,0,0"
                                        Padding="22,10" FontSize="12" FontWeight="Bold" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent"
                                                    BorderBrush="{StaticResource B1}" BorderThickness="1"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background"><Setter.Value><SolidColorBrush Color="#145A2A2A"/></Setter.Value></Setter>
                                                    <Setter TargetName="bd" Property="BorderBrush"><Setter.Value><SolidColorBrush Color="#FF5A2A2A"/></Setter.Value></Setter>
                                                    <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Foreground><SolidColorBrush Color="#FF3A3A38"/></Button.Foreground>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
