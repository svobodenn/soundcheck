<UserControl x:Class="SoundCheck.Views.Toast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False"
             Opacity="0">
    <UserControl.RenderTransformOrigin>0.5,1</UserControl.RenderTransformOrigin>
    <UserControl.RenderTransform>
        <TransformGroup>
            <ScaleTransform x:Name="ToastScale" ScaleX="0.94" ScaleY="0.94"/>
            <TranslateTransform x:Name="ToastTrans" Y="20"/>
        </TransformGroup>
    </UserControl.RenderTransform>
    <Border x:Name="Card"
            HorizontalAlignment="Center" VerticalAlignment="Bottom"
            Margin="0,0,0,132"
            Background="#F0121212"
            BorderBrush="{StaticResource B1}" BorderThickness="1"
            CornerRadius="11"
            Padding="14,12,18,12">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="36" ShadowDepth="14" Opacity="0.55"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="TxtMsg" Foreground="{StaticResource T1}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
