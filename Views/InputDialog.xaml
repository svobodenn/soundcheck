<UserControl x:Class="SoundCheck.Views.InputDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#CC050505"
             Opacity="0"
             Visibility="Collapsed"
             RenderTransformOrigin="0.5,0.5">
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="IdScale" ScaleX="0.94" ScaleY="0.94"/>
    </UserControl.RenderTransform>
    <Grid x:Name="BackdropGrid" Background="Transparent" MouseLeftButtonDown="Backdrop_MouseDown">
        <Border Width="420" MaxWidth="500"
                Background="{StaticResource Sb}"
                BorderBrush="{StaticResource B1}" BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="28,26,28,22"
                MouseLeftButtonDown="Card_MouseDown">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="12" Opacity="0.55"/>
            </Border.Effect>
            <StackPanel>
                <Border Background="{DynamicResource Accent}" Height="3" Width="40" CornerRadius="2"
                        HorizontalAlignment="Left" Margin="0,0,0,16"/>
                <TextBlock x:Name="TxtTitle" Text=""
                           Foreground="{StaticResource T3}" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,12"/>
                <Grid Margin="0,0,0,24">
                    <Border Background="{StaticResource S1}" BorderBrush="{StaticResource B1}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                        <TextBox x:Name="TxtInput" Background="Transparent" Foreground="{StaticResource T1}"
                                 CaretBrush="{StaticResource T1}" BorderThickness="0" FontSize="14"/>
                    </Border>
                    <TextBlock x:Name="TxtPlaceholder" Text="" Foreground="{StaticResource T3}" FontSize="14"
                               Margin="14,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancel" Content="{DynamicResource L_ConfirmCancel}" Click="Cancel_Click" Margin="0,0,10,0"
                            FontWeight="Bold" FontSize="11" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" BorderBrush="{StaticResource B1}" BorderThickness="1" CornerRadius="7" Padding="20,9">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                                        <Setter Property="Foreground" Value="{StaticResource T1}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground><SolidColorBrush Color="#FF686460"/></Button.Foreground>
                    </Button>
                    <Button x:Name="BtnOk" Content="{DynamicResource L_ConfirmOk}" Click="Ok_Click"
                            FontWeight="Bold" FontSize="11" Cursor="Hand" Foreground="{DynamicResource Accent}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" BorderBrush="{DynamicResource AccentDim}" BorderThickness="1" CornerRadius="7" Padding="20,9">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource S2}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
